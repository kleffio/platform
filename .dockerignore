# Version control
.git
.gitignore

# Go build artifacts
bin/
**/*.exe
**/*.test
**/vendor/

# Environment files — never bake secrets into images
**/.env
**/.env.local
**/.env.*.local

# Editor & OS
.vscode
.idea
**/.DS_Store
**/Thumbs.db

# Infra config — not needed inside app image
infra/
argocd/

# Docs
**/*.md

# Docker files themselves
Dockerfile*
docker-compose*
