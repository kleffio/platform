# Server
HTTP_PORT=8080
LOG_LEVEL=info

# Database
DATABASE_URL=postgres://kleff:kleff@localhost:5432/kleff?sslmode=disable

# OIDC / token introspection
# Works with any RFC 7662-compliant provider (Keycloak, Authentik, Ory Hydra, Auth0, etc.)
OIDC_AUTHORITY=http://localhost:8180/realms/kleff
OIDC_CLIENT_ID=kleff-panel
OAUTH2_INTROSPECT_URL=http://localhost:8180/realms/kleff/protocol/openid-connect/token/introspect

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Headless registration (optional) ──────────────────────────────────────────
# Enables POST /api/v1/auth/register so the panel can render its own sign-up
# form instead of redirecting to the identity provider's login page.
#
# The platform POSTs the following JSON to REGISTRATION_WEBHOOK_URL and relays
# the response back to the panel:
#   { "username": "...", "email": "...", "password": "..." }
#
# Point this at any small service that creates users in your IDP.
# Leave unset to disable (the sign-up button will redirect to your IDP instead).
#
# REGISTRATION_WEBHOOK_URL=http://localhost:9000/register
